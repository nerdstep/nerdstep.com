---
import '~/assets/styles/base.css';
import BasicScripts from '~/components/common/BasicScripts.astro';
import MetaTags from '~/components/common/MetaTags.astro';
import { SITE } from '~/config.mjs';
import { MetaSEO } from '~/types';

export interface Props {
  meta?: MetaSEO;
}

const { meta = {} } = Astro.props;
const { language = 'en', textDirection = 'ltr' } = SITE;
---

<!DOCTYPE html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <MetaTags {...meta} />
  </head>
  <body class="min-h-screen flex flex-col antialiased tracking-tight text-gray-900 dark:text-slate-300 bg-white/90 dark:bg-slate-900/90">
    <slot />
    <BasicScripts />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
