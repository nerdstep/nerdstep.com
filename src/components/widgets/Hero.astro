---
import { Image } from '@astrojs/image/components';
import imgProfile from '~/assets/images/professional_256.jpg';
import Container from './Container.astro';
---

<section>
  <Container>
    <div class="py-12 md:py-20">
      <div class="p-6 md:p-12 max-w-xl mx-auto backdrop-blur-sm text-center rounded-2xl shadow-2xl border border-white/90 dark:border-slate-400/20 bg-white/5 dark:bg-slate-900/60">
        <Image
          class="mx-auto rounded-full p-1 mb-6 border-2 border-slate-600 dark:border-slate-300"
          src={imgProfile}
          alt="Profile picture"
        />
        <h1 class="text-5xl md:text-[3.50rem] font-heading font-bold leading-tighter tracking-tighter mb-4 ">
          Hello world.
        </h1>
        <p class="text-xl font-medium text-gray-500 dark:text-slate-400">
          Under Construction
        </p>
      </div>
    </div>
  </Container>
</section>
